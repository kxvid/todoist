# Todoist API token — Todoist → Settings → Integrations → Developer
TODOIST_API_TOKEN=...

# Single-user gate. Anything you want; gates the web UI and API.
APP_PASSWORD=change-me

# NOTE: model API keys are no longer set here.
# Each user pastes their own key in the Settings panel after signing in (BYOK).
# The server reads it from a request header per request and never persists it.
